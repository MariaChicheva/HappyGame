<Window x:Class="HappyGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HappyGame"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="840" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" WindowStyle="None" KeyDown="Window_KeyDown" >
    <Canvas x:Name="GameCanvas" Width="840" Height="650" ClipToBounds="True">
        <Image x:Name="Road" Canvas.Top="0" Height="650" Width="840" Source="/Images/road.png"/>
        <Image x:Name="RoadBack" Canvas.Top="-650" Height="650" Width="840" Source="/Images/road.png"/>
        <Image Height="150" Width="200" Source="/Images/yellowcar.png" Margin="515,474,125,26"/>
    </Canvas>
</Window>
